# Momentum Environment Configuration
# Copy this file to .env.local and fill in your values

# =============================================================================
# AI Provider Configuration (At least one required for production)
# =============================================================================

# Google Gemini API Key - For AI planning and task generation
# Get your key at: https://makersuite.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=

# Backboard API Key - For AI memory and assistant features
# Get your key at: https://app.backboard.io
BACKBOARD_API_KEY=

# =============================================================================
# OpenClaw Configuration (Local AI Gateway)
# =============================================================================

# OpenClaw local gateway URL - For running AI agents locally
# Default: http://localhost:5100
# Install OpenClaw: pip install openclaw
# Run: openclaw serve
OPENCLAW_URL=http://localhost:5100

# =============================================================================
# Application Mode
# =============================================================================

# Set to "production" to disable demo features and mock data
# Set to "demo" to enable all demo features (default)
NEXT_PUBLIC_APP_MODE=demo

# =============================================================================
# Database Configuration
# =============================================================================

# SQLite database path (default: ./momentum.db)
DATABASE_PATH=./momentum.db

# =============================================================================
# Notion MCP Configuration (For Notion AI Challenge)
# =============================================================================

# Notion Integration Token - Get from https://www.notion.so/profile/integrations
# Create an internal integration and copy the token (starts with ntn_)
NOTION_TOKEN=

# Notion MCP Server URL (default: http://localhost:3100/mcp)
# Run: NOTION_TOKEN=ntn_xxx npx -y @notionhq/notion-mcp-server --transport http --port 3100
NOTION_MCP_URL=http://localhost:3100/mcp

# Optional: Auth token for MCP server (if using --auth-token flag)
NOTION_MCP_TOKEN=

# Default Notion Database ID for task sync (optional - can be set per project)
NOTION_DEFAULT_DATABASE_ID=
